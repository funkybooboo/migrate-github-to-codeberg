# ---------------------------------------------------------------------------
# Shared configuration for all migration scripts. Copy to ".env" and fill in:
#     cp .env.example .env
# Every script sources this same file (./.env) — leave unused vars at their
# defaults. Variables marked "required" must be set or the scripts will refuse
# to run.
# ---------------------------------------------------------------------------

# REQUIRED — GitHub credentials (token needs 'repo' scope)
GITHUB_USERNAME="YourGitHubUsername"
GITHUB_TOKEN="YourGitHubToken"

# Target Forgejo instance base URL — defaults to Codeberg if unset.
# Point this at any Gitea/Forgejo host to mirror there instead of Codeberg.
# FORGEJO_BASE_URL="https://codeberg.org"
# FORGEJO_BASE_URL="https://your.forgejo.instance"

# REQUIRED — Codeberg/Forgejo credentials
CODEBERG_USERNAME="YourCodebergUsername"
CODEBERG_TOKEN="YourCodebergToken"

# Repos to migrate — empty array migrates all repos you own.
# Used by: migrate_github_to_codeberg.sh, mark_github_migrated.sh,
#          migrate_issues_to_codeberg.sh, create_pr_references.sh
REPOSITORIES=()
# REPOSITORIES=(
#     "my-project"
#     "dotfiles"
# )

# Filter by owner login — empty array includes all owners. Only applies when
# REPOSITORIES is empty (explicit REPOSITORIES are always processed).
# Used by: migrate_github_to_codeberg.sh, mark_github_migrated.sh,
#          migrate_issues_to_codeberg.sh, create_pr_references.sh
OWNERS=()
# OWNERS=(
#     "myusername"
#     "some-org"
# )

# Prepended to each repo description — leave empty for none.
# Used by: migrate_github_to_codeberg.sh
DESCRIPTION_PREFIX=""
# DESCRIPTION_PREFIX="[MIRROR] "

# ---------------------------------------------------------------------------
# Rate-limit / pagination tuning (shared by all scripts)
# ---------------------------------------------------------------------------

# Seconds to wait between Codeberg migration API calls (community rec: 2)
CODEBERG_REQUEST_DELAY=2

# GitHub API pagination — max allowed by the API is 100
GITHUB_PAGE_SIZE=100

# Codeberg API pagination — max allowed by the API is 50
CODEBERG_PAGE_SIZE=50

# Maximum number of retries on HTTP 429 before giving up
CURL_MAX_RETRIES=5

# Fallback wait (seconds) on HTTP 429 when no retry-after header is present
CURL_RETRY_AFTER_DEFAULT=60

# ---------------------------------------------------------------------------
# mark_github_migrated.sh — archive GitHub repos + add migration pointers
# ---------------------------------------------------------------------------

# Migration messaging
MIGRATION_NOTICE="This repository has been migrated to Codeberg. Active development continues there."
MIGRATION_PREFIX="[ARCHIVED] Migrated to Codeberg: "

# Seconds to wait between GitHub repo updates during archive/marking (default: 1)
MARK_REQUEST_DELAY=1

# Disable issues, projects, and wiki on the archived GitHub repos
DISABLE_ISSUES=true
DISABLE_PROJECTS=true
DISABLE_WIKI=true

# Create a pinned "we moved" issue on each archived GitHub repo
CREATE_PINNED_ISSUE=true

# ---------------------------------------------------------------------------
# migrate_issues_to_codeberg.sh — copy issues + comments to Codeberg
# ---------------------------------------------------------------------------

# Migrate closed issues (not just open ones)
MIGRATE_CLOSED=true

# Copy each issue's comments as Codeberg issue comments
MIGRATE_COMMENTS=true

# Re-apply GitHub labels to the migrated Codeberg issues (labels that don't
# exist on Codeberg are skipped silently)
PRESERVE_LABELS=true

# ---------------------------------------------------------------------------
# update_github_profile.sh — point your GitHub profile at Codeberg
# ---------------------------------------------------------------------------

# New GitHub profile bio. Embed your Codeberg URL so visitors follow you over.
PROFILE_BIO="Moved to Codeberg -> https://codeberg.org/YourCodebergUsername"

# Prepend a migration banner to your profile README repo (<user>/<user>).
# Set to false to only update the bio.
UPDATE_README=true
